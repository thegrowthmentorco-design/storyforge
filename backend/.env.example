# Copy this to .env and fill in your key. backend/.env is gitignored via .dockerignore.
# Without a key, the backend runs in mock mode and the UI shows the "Mock mode" badge.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model. claude-opus-4-7 (default) | claude-sonnet-4-6 | claude-haiku-4-5
# STORYFORGE_MODEL=claude-opus-4-7

# M3.4.6 — BYOK deployment shape. One of:
#   strict  (default) — every user must bring their own key. Server's
#                       ANTHROPIC_API_KEY is NOT used for live extractions.
#   managed           — server pays. Every extraction uses ANTHROPIC_API_KEY
#                       above; user-stored keys are ignored and the BYOK
#                       form is hidden in the UI.
#   choice            — user can BYOK if they want; otherwise server's key
#                       fills in. Header > stored > env precedence.
# STORYFORGE_BYOK_MODE=strict
