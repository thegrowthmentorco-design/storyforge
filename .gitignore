# --- Secrets — must never be committed ---
**/.env
**/.env.*
!**/.env.example

# --- Python ---
backend/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/htmlcov/
**/.coverage

# --- Node / Vite ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
**/npm-debug.log*

# --- Backend runtime data (out of repo) ---
backend/uploads/
backend/storyforge.db
backend/*.sqlite
backend/*.sqlite3

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# --- Logs / temp ---
*.log
/tmp/
