# --- Secrets — must never be committed ---
**/.env
**/.env.*
!**/.env.example

# --- Python ---
backend/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/htmlcov/
**/.coverage
**/.coverage.*
**/coverage.xml
**/*.egg-info/
**/build/

# --- Node / Vite / Vitest / Playwright ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.eslintcache
**/npm-debug.log*
# Playwright (M0.1.3 — when added)
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# --- Backend runtime data (out of repo) ---
backend/uploads/
backend/storyforge.db
backend/*.sqlite
backend/*.sqlite3

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# --- Logs / temp ---
*.log
/tmp/
